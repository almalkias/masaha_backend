msgid "Passwords do not match."
msgstr "كلمتا المرور غير متطابقتين."

#: accounts/serializers.py:67
msgid "Current password is incorrect."
msgstr "كلمة المرور الحالية غير صحيحة."

#: accounts/serializers.py:127
msgid "The new email address is the same as the current one."
msgstr "البريد الإلكتروني الجديد مطابق للبريد الحالي."

#: accounts/serializers.py:132
msgid "This email is already in use."
msgstr "هذا البريد الإلكتروني مستخدم بالفعل."

#: accounts/serializers.py:198
msgid "Invalid reset link."
msgstr "رابط إعادة التعيين غير صالح."

#: accounts/serializers.py:203
msgid "Invalid or expired reset token."
msgstr "رمز إعادة التعيين غير صالح أو منتهي الصلاحية."

#: accounts/views.py:27
msgid "User created successfully"
msgstr "تم إنشاء الحساب بنجاح."

#: accounts/views.py:74
msgid "Refresh token is required"
msgstr "رمز التحديث مطلوب."

#: accounts/views.py:79
msgid "Logged out successfully"
msgstr "تم تسجيل الخروج بنجاح."

#: accounts/views.py:81
msgid "Invalid or expired token"
msgstr "الرمز غير صالح أو منتهي الصلاحية."

#: accounts/views.py:98
msgid "Password updated successfully"
msgstr "تم تحديث كلمة المرور بنجاح."

#: accounts/views.py:110
msgid "If an account with this email exists, a reset link has been sent."
msgstr "إذا كان البريد الإلكتروني مسجلاً، سيتم إرسال رابط إعادة التعيين."

#: accounts/views.py:124
msgid "Password has been reset successfully."
msgstr "تم إعادة تعيين كلمة المرور بنجاح."

